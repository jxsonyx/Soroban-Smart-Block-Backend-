// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Ledger (block) — one row per closed ledger.
// sequence is the natural PK; closeTime enables timestamp-range queries.
model Ledger {
  sequence     Int      @id                // ledger sequence number (block number)
  hash         String   @unique            // ledger hash
  closeTime    DateTime                    // ledger close timestamp
  txCount      Int      @default(0)        // number of transactions in this ledger
  createdAt    DateTime @default(now())

  transactions Transaction[]
  events       Event[]

  @@index([sequence])                      // sub-second lookup by ledger number
  @@index([closeTime])                     // range queries by timestamp
}

model Contract {
  id                 String   @id @default(cuid())
  address            String   @unique
  name               String?
  description        String?
  abi                Json?    // ABI-like metadata: functions, events, types
  functionSignatures Json?    // decoded function signatures: [{ name, inputs, outputs }]
  isToken            Boolean  @default(false)
  tokenSymbol        String?
  tokenName          String?
  tokenDecimals      Int?
  wasmHash           String?  // fuzzy hash of compiled Wasm bytecode for similarity detection
  isVerified         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  transactions Transaction[]
  events       Event[]
  wasmUpgrades WasmUpgradeHistory[]

  @@index([address])
}

// WASM bytecode upgrade history for contract version lineage
model WasmUpgradeHistory {
  id              String   @id @default(cuid())
  contractAddress String
  previousHash    String?  // hash before upgrade (null for initial deployment)
  newHash         String   // hash after upgrade
  ledgerSequence  Int      // ledger where upgrade occurred
  ledgerCloseTime DateTime // timestamp of upgrade
  transactionHash String?  // tx that triggered the upgrade
  createdAt       DateTime @default(now())

  contract Contract @relation(fields: [contractAddress], references: [address])

  @@index([contractAddress, ledgerSequence])
  @@index([ledgerSequence])
}

model Transaction {
  id              String   @id @default(cuid())
  hash            String   @unique
  ledgerSequence  Int                      // FK → Ledger.sequence
  ledgerCloseTime DateTime
  sourceAccount   String
  contractAddress String?
  functionName    String?
  functionArgs    Json?    // decoded args
  rawXdr          String
  status          String   // success | failed
  humanReadable   String?  // "Address X swapped 100 USDC → 98.7 XLM"
  feeCharged      String?
  sorobanResources Json?   // #48: CPU, memory, ledger footprint metrics
  failureReason   String?  // #49: human-readable failure explanation
  flashLoanAlert  Boolean  @default(false) // #137: flash loan attack detected
  createdAt       DateTime @default(now())

  ledger   Ledger    @relation(fields: [ledgerSequence], references: [sequence])
  contract Contract? @relation(fields: [contractAddress], references: [address])
  events   Event[]

  @@index([hash])                          // sub-second lookup by tx hash
  @@index([ledgerSequence])               // sub-second lookup by ledger number
  @@index([sourceAccount])
  @@index([contractAddress])
  @@index([status])
  // Composite indexes for cursor-based pagination (ledgerSequence DESC, id DESC)
  @@index([contractAddress, ledgerSequence, id])
  @@index([sourceAccount, ledgerSequence, id])
  @@index([status, ledgerSequence, id])
  @@index([ledgerSequence, id])
}

model Event {
  id              String   @id @default(cuid())
  transactionHash String
  contractAddress String
  eventType       String   // transfer | swap | mint | burn | custom
  topicSymbol     String?  // first topic decoded as symbol (e.g. "transfer", "mint_pass")
  topics          Json     // raw topics (base64 XDR array)
  data            Json     // raw data (base64 XDR)
  decoded         Json?    // human-readable decoded event
  ledgerSequence  Int                      // FK → Ledger.sequence
  ledgerCloseTime DateTime
  createdAt       DateTime @default(now())

  ledger      Ledger      @relation(fields: [ledgerSequence], references: [sequence])
  transaction Transaction @relation(fields: [transactionHash], references: [hash])
  contract    Contract    @relation(fields: [contractAddress], references: [address])

  @@index([transactionHash])
  @@index([contractAddress])
  @@index([eventType])
  @@index([topicSymbol])
  @@index([ledgerSequence])
  // Heavy-use composite: filter by contract + topic symbol (event name)
  @@index([contractAddress, topicSymbol])
  // Cursor-based pagination: contract + ledger desc
  @@index([contractAddress, ledgerSequence, id])
  // Filter by contract + event type + ledger for time-range queries
  @@index([contractAddress, eventType, ledgerSequence])
}

// Custom event symbol → template bindings submitted by verified project creators
model EventDefinition {
  id              String   @id @default(cuid())
  contractAddress String
  // The event topic symbol this binding applies to, e.g. "mint_pass"
  topicSymbol     String
  // Mustache-style template, e.g. "Minted pass #{{data.id}} to {{data.owner}}"
  humanTemplate   String
  // Who submitted this definition (API key or creator identifier)
  submittedBy     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([contractAddress, topicSymbol])
  @@index([contractAddress])
}

// Privacy-shielded transfer tracking for zero-knowledge privacy pools
model ShieldedTransfer {
  id              String   @id @default(cuid())
  transactionHash String
  contractAddress String   // privacy pool contract
  fromAddress     String?  // null if shielded
  toAddress       String?  // null if shielded
  amount          String?  // null if confidential
  isConfidential   Boolean  @default(true)
  ledgerSequence  Int
  ledgerCloseTime DateTime
  createdAt       DateTime @default(now())

  @@index([transactionHash])
  @@index([contractAddress, ledgerSequence])
}

// ZKP verification event tracking
model ZkpVerificationEvent {
  id              String   @id @default(cuid())
  transactionHash String
  contractAddress String   // ZKP verifier contract
  proofType       String   // snark | stark | groth16 | etc
  publicInputHash String   // hash of public inputs
  verificationResult String // verified | failed
  certaintyPercent Float?   // cryptographic certainty level
  ledgerSequence  Int
  ledgerCloseTime DateTime
  createdAt       DateTime @default(now())

  @@index([transactionHash])
  @@index([contractAddress, ledgerSequence])
}

model IndexerState {
  id         String   @id @default("singleton")
  lastLedger Int      @default(0)
  updatedAt  DateTime @updatedAt
}

// Bidirectional mapping: classic Stellar asset ↔ SAC contract address
model SacMapping {
  id           String   @id @default(cuid())
  // Classic asset fields
  assetCode    String   // e.g. "USDC"
  assetIssuer  String?  // null for XLM (native)
  assetType    String   // "native" | "credit_alphanum4" | "credit_alphanum12"
  // Soroban side
  sacAddress   String   @unique  // derived C-address of the SAC contract
  // Metadata
  firstSeenLedger Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ammPools     AmmPool[]

  @@unique([assetCode, assetIssuer])
  @@index([sacAddress])
  @@index([assetCode])
}

// AMM pool that uses one or more SAC-wrapped assets
model AmmPool {
  id              String   @id @default(cuid())
  poolAddress     String   @unique  // Soroban contract address of the pool
  poolType        String   @default("constant_product")  // constant_product | stable
  // The two assets in the pool (at least one is a SAC)
  assetAAddress   String   // SAC address or native token address
  assetBAddress   String
  // Reverse links to SacMapping (nullable — one side may be a non-SAC token)
  sacMappingAId   String?
  sacMappingBId   String?
  sacMappingA     SacMapping? @relation(fields: [sacMappingAId], references: [id])
  firstSeenLedger Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([assetAAddress])
  @@index([assetBAddress])
}

model VerificationJob {
  id              String   @id @default(cuid())
  contractAddress String?  // on-chain address to compare against
  toolchain       String   @default("soroban-cli@0.9.4") // pinned toolchain version
  status          String   @default("pending") // pending | compiling | verified | failed
  uploadedHash    String?  // SHA-256 of uploaded archive
  onChainWasmHash String?  // hash fetched from RPC
  compiledWasmHash String? // hash of compiled output
  matched         Boolean?
  errorMsg        String?
  logs            String?  // compiler stdout/stderr
  sourceFiles     Json?    // extracted source files: [{ path, content }]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([contractAddress])
  @@index([status])
}

model SandboxSession {
  id                 String   @id @default(cuid())
  userId             String?  @map("user_id")
  status             String   // active | paused | expired | destroyed
  ledgerSequence     Int      @default(1) @map("ledger_sequence")
  ledgerTimestamp    DateTime @map("ledger_timestamp") @default(now())
  networkPassphrase  String   @map("network_passphrase")
  maxContractSize    Int      @default(102400) @map("max_contract_size")
  maxCpuInsn         Int      @default(10000000) @map("max_cpu_insn")
  maxMemBytes        Int      @default(1048576) @map("max_mem_bytes")
  seed               String?
  config             Json?
  state              Json?
  createdAt          DateTime @map("created_at") @default(now())
  expiresAt          DateTime @map("expires_at")
  lastAccessed       DateTime @map("last_accessed") @updatedAt

  @@index([userId, status])
  @@index([expiresAt])
  @@map("sandbox_sessions")
}

model SandboxAccount {
  id              String   @id @default(cuid())
  sessionId       String   @map("session_id")
  publicKey       String   @map("public_key")
  label           String?
  balance         Decimal
  sequenceNumber  Int      @map("sequence_number") @default(0)
  isPreFunded     Boolean  @default(false) @map("is_pre_funded")

  @@index([sessionId])
  @@unique([sessionId, publicKey])
  @@map("sandbox_accounts")
}

model SandboxContract {
  id              String   @id @default(cuid())
  sessionId       String   @map("session_id")
  contractId      String   @map("contract_id")
  name            String?
  wasmHash        String   @map("wasm_hash")
  deployerAccount String   @map("deployer_account")
  sourceContract  String?  @map("source_contract")
  templateId      String?  @map("template_id")
  deployedAt      DateTime @map("deployed_at")
  lastCalledAt    DateTime? @map("last_called_at")
  totalCalls      Int      @default(0) @map("total_calls")
  abi             Json?
  state           Json?

  @@index([sessionId])
  @@unique([sessionId, contractId])
  @@map("sandbox_contracts")
}

model SandboxCall {
  id              String   @id @default(cuid())
  sessionId       String   @map("session_id")
  contractId      String   @map("contract_id")
  functionName    String   @map("function_name")
  args            Json
  sourceAccount   String   @map("source_account")
  success         Boolean
  result          Json?
  error           String?
  events          Json?
  cpuInsnUsed     Int      @map("cpu_insn_used")
  memBytesUsed    Int      @map("mem_bytes_used")
  readBytes       Int      @map("read_bytes")
  writeBytes      Int      @map("write_bytes")
  callIndex       Int      @map("call_index")
  batchId         String?  @map("batch_id")
  createdAt       DateTime @map("created_at")

  @@index([sessionId, createdAt(sort: Desc)])
  @@index([contractId])
  @@index([batchId])
  @@map("sandbox_calls")
}

model SandboxSnapshot {
  id              String   @id @default(cuid())
  sessionId       String   @map("session_id")
  name            String
  state           Json
  createdAt       DateTime @map("created_at")

  @@index([sessionId])
  @@map("sandbox_snapshots")
}

model ContractTemplate {
  id              String   @id @default(cuid())
  name            String
  description     String?
  category        String
  wasmBase64      String   @map("wasm_base64")
  abi             Json
  defaultArgs     Json?    @map("default_args")
  deploymentGuide String?  @map("deployment_guide")
  version         String
  author          String?
  createdAt       DateTime @map("created_at")

  @@map("contract_templates")
}

model FuzzRun {
  id              String   @id @default(cuid())
  sessionId       String   @map("session_id")
  contractId      String   @map("contract_id")
  status          String
  strategies      Json
  totalIterations Int      @map("total_iterations")
  uniqueFindings  Int      @map("unique_findings")
  startedAt       DateTime @map("started_at")
  completedAt     DateTime? @map("completed_at")

  @@index([sessionId])
  @@map("fuzz_runs")
}

model FuzzFinding {
  id              String   @id @default(cuid())
  fuzzRunId       String   @map("fuzz_run_id")
  severity        String
  title           String
  description     String
  callSequence    Json     @map("call_sequence")
  stateDump       Json?    @map("state_dump")
  reproducible    Boolean  @default(true)
  createdAt       DateTime @map("created_at")

  @@index([fuzzRunId])
  @@map("fuzz_findings")
}

model SandboxCiRun {
  id              String   @id @default(cuid())
  sessionId       String?  @map("session_id")
  status          String   // running | passed | failed | cancelled
  steps           Json
  logs            Json
  result          Json?
  createdAt       DateTime @map("created_at")
  completedAt     DateTime? @map("completed_at")

  @@index([sessionId])
  @@index([status])
  @@map("sandbox_ci_runs")
}

model SandboxShare {
  id              String   @id @default(cuid())
  sessionId       String   @map("session_id")
  shareId         String   @unique @map("share_id")
  viewOnly        Boolean  @default(true) @map("view_only")
  snapshotState   Json     @map("snapshot_state")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime @map("created_at")

  @@index([sessionId])
  @@index([expiresAt])
  @@map("sandbox_shares")
}

// Persistent contract state key tracking for eviction monitoring (#57, #58)
model ContractState {
  id                String   @id @default(cuid())
  contractAddress   String
  ledgerKey         String   // base64 XDR of the LedgerKey
  keyType           String   // "contractData" | "contractCode" | "account"
  status            String   @default("Live")  // "Live" | "Archived" | "Dead"
  liveUntilLedgerSeq Int?    // from TTL entry; null = unknown
  lastSeenLedger    Int
  restoredAtLedger  Int?     // set when status transitions back to Live
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([contractAddress, ledgerKey])
  @@index([contractAddress])
  @@index([status])
  @@index([liveUntilLedgerSeq])
}

// Log of RestoreFootprintOp restorations (#58)
model RestorationLog {
  id              String   @id @default(cuid())
  transactionHash String   @unique
  sourceAccount   String
  ledgerSequence  Int
  ledgerCloseTime DateTime
  feeCharged      String?
  restoredKeys    Json     // array of { ledgerKey, contractAddress }
  createdAt       DateTime @default(now())

  @@index([sourceAccount])
  @@index([ledgerSequence])
}

model FailedItem {
  id          String   @id @default(cuid())
  itemType    String   // "transaction" | "event"
  itemId      String   // tx hash or event id
  ledger      Int
  rawXdr      String?  // raw XDR that failed to decode
  errorMsg    String
  errorStack  String?
  context     Json?    // extra context (topics, data, etc.)
  retryCount  Int      @default(0)
  dead        Boolean  @default(false)  // true = max retries exceeded
  createdAt   DateTime @default(now())
  lastTriedAt DateTime @default(now())

  @@index([itemType, dead])
  @@index([ledger])
}

// Storage efficiency: tracks allocated footprint bytes vs actual data bytes per tx
model StorageEfficiencyLog {
  id              String   @id @default(cuid())
  transactionHash String   @unique
  contractAddress String?
  ledgerSequence  Int
  // Footprint (what the tx declared it would read/write)
  readOnlyKeys    Int      @default(0)   // number of read-only footprint keys
  readWriteKeys   Int      @default(0)   // number of read-write footprint keys
  footprintBytes  Int      @default(0)   // total allocated byte budget
  // Actual usage
  actualReadBytes  Int     @default(0)   // bytes actually read
  actualWriteBytes Int     @default(0)   // bytes actually written
  // Derived efficiency metrics
  unusedBytes     Int      @default(0)   // footprintBytes - (actualReadBytes + actualWriteBytes)
  efficiencyPct   Float    @default(0)   // (actual / footprint) * 100
  createdAt       DateTime @default(now())

  @@index([contractAddress])
  @@index([ledgerSequence])
  @@index([efficiencyPct])
}

// Async CSV export jobs
model ExportJob {
  id          String   @id @default(cuid())
  status      String   @default("pending")  // pending | running | done | failed
  exportType  String   // "transactions" | "events"
  filters     Json?    // serialised query filters (contract, account, ledgerMin, etc.)
  filePath    String?  // path to generated CSV file once done
  rowCount    Int?     // number of rows exported
  errorMsg    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Signer state snapshot per transaction for multi-sig smart accounts
model SignerSnapshot {
  id              String   @id @default(cuid())
  transactionHash String   @unique
  contractAddress String   // the smart-account contract
  ledgerSequence  Int
  // Threshold configuration at time of tx
  lowThreshold    Int      @default(0)
  medThreshold    Int      @default(0)
  highThreshold   Int      @default(0)
  // Signer participation
  signers         Json     // array of { key, weight, signed: bool }
  weightAchieved  Int      @default(0)   // sum of weights of keys that signed
  thresholdMet    String   // "low" | "medium" | "high" | "none"
  passed          Boolean  @default(false)
  // Margin analysis
  marginToNext    Int?     // weight needed to reach next threshold level
  createdAt       DateTime @default(now())

  @@index([contractAddress])
  @@index([ledgerSequence])
  @@index([passed])
}

// Institutional treasury wallet multi-sig auditor
model TreasuryWallet {
  id                String   @id @default(cuid())
  address           String   @unique
  name              String
  requiredThreshold Int      // minimum signature weight required
  totalSigners       Int      // total number of signers
  adminEmail        String?  // for alert notifications
  lastAuditLedger   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  auditSnapshots    TreasuryAuditSnapshot[]

  @@index([address])
}

// Periodic audit snapshot of treasury wallet safety metrics
model TreasuryAuditSnapshot {
  id                String   @id @default(cuid())
  treasuryId        String
  ledgerSequence    Int
  ledgerCloseTime   DateTime
  // Balance tracking
  totalBalance      String   // in stroops
  balanceThreshold  String   // minimum safe balance
  balanceHealthy    Boolean  // totalBalance >= balanceThreshold
  // Multi-sig configuration
  activeSigners     Int      // current active signers
  thresholdMet      Boolean  // activeSigners >= requiredThreshold
  configurationChanged Boolean @default(false)
  // Alert status
  alertSent         Boolean  @default(false)
  alertReason       String?  // "low_balance" | "config_change" | "signer_change"
  createdAt         DateTime @default(now())

  treasury          TreasuryWallet @relation(fields: [treasuryId], references: [id])

  @@index([treasuryId])
  @@index([ledgerSequence])
  @@index([alertSent])
}

// OFAC sanctioned address registry
model SanctionedAddress {
  id              String   @id @default(cuid())
  address         String   @unique
  name            String?
  jurisdiction    String?  // country/region
  listSource      String   // "OFAC" | "EU" | "UN" | "custom"
  addedAt         DateTime @default(now())
  updatedAt       DateTime @updatedAt

  complianceFlags ComplianceFlag[]

  @@index([address])
  @@index([listSource])
}

// Compliance flag on transactions/accounts
model ComplianceFlag {
  id                String   @id @default(cuid())
  transactionHash   String?  // null if flagging an account
  sourceAccount     String?
  destinationAccount String?
  sanctionedAddressId String
  flagType          String   // "sender_sanctioned" | "receiver_sanctioned" | "both"
  severity          String   // "high" | "medium" | "low"
  reviewed          Boolean  @default(false)
  reviewedBy        String?
  reviewedAt        DateTime?
  notes             String?
  createdAt         DateTime @default(now())

  sanctionedAddress SanctionedAddress @relation(fields: [sanctionedAddressId], references: [id])

  @@index([transactionHash])
  @@index([sourceAccount])
  @@index([destinationAccount])
  @@index([reviewed])
  @@index([severity])
}

// Tax lot for cost-basis tracking (IRS Form 8949)
model TaxLot {
  id              String   @id @default(cuid())
  walletAddress   String
  assetSymbol     String   // e.g., "USDC", "XLM"
  quantity        String   // decimal string
  costBasisPerUnit String  // in USD or reference currency
  totalCostBasis  String   // quantity * costBasisPerUnit
  acquisitionDate DateTime
  disposalDate    DateTime?
  disposalPrice   String?  // price per unit at disposal
  gainLoss        String?  // (disposalPrice - costBasisPerUnit) * quantity
  transactionHash String?  // link to original tx
  createdAt       DateTime @default(now())

  @@index([walletAddress])
  @@index([assetSymbol])
  @@index([acquisitionDate])
  @@index([disposalDate])
}

// Tax export job for Form 8949 CSV generation
model TaxExportJob {
  id              String   @id @default(cuid())
  walletAddress   String
  taxYear         Int
  status          String   @default("pending")  // pending | processing | completed | failed
  filePath        String?  // path to generated CSV
  totalLots       Int?
  totalGain       String?  // sum of all gains
  totalLoss       String?  // sum of all losses
  errorMsg        String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([walletAddress])
  @@index([taxYear])
  @@index([status])
}

// i18n translation dictionary
model TranslationKey {
  id              String   @id @default(cuid())
  key             String   @unique  // e.g., "transaction.swap_description"
  defaultText     String   // English template with {placeholders}
  context         String?  // usage context for translators
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  translations    Translation[]

  @@index([key])
}

// Translated text for a specific language
model Translation {
  id              String   @id @default(cuid())
  keyId           String
  language        String   // e.g., "es", "ko", "fr"
  translatedText  String   // translated template with {placeholders}
  approvedBy      String?  // translator/reviewer
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  key             TranslationKey @relation(fields: [keyId], references: [id])

  @@unique([keyId, language])
  @@index([language])
}




